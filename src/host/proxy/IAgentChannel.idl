//
// Classic-COM PoC for the agent protocol transport.
//
// This mirrors ITerminalHandoff: plain [object] : IUnknown interfaces whose
// cross-process marshaling is handled by the MIDL-generated proxy/stub built
// into OpenConsoleProxy.dll. Unlike the WinRT/Metadata-Based-Marshaling path
// used by IProtocolServer, activating and marshaling these interfaces does NOT
// consult the WinRT activation catalog (CWinRTActivationStoreCatalog) — the
// component implicated in the combase 0xc0000005 / 0x80010105 failures.
//
// Goal of the PoC: prove the hardest feature (a cross-process *event* callback)
// works over classic COM, and that it does not crash on affected machines.

import "unknwn.idl";

// LOAD BEARING (same discipline as ITerminalHandoff): OpenConsoleProxy.dll is a
// single shared proxy/stub DLL. Never change or reuse the UUIDs below; only add
// new versioned interfaces.

// Event sink — implemented by the CLIENT (wtcli). The server calls back into
// this interface cross-process to push events.
[
    object,
    uuid(2C9D5F08-1A6B-47E3-9B4F-8D0E1C2A3B5F),
    pointer_default(unique)
] interface IAgentChannelSink : IUnknown
{
    HRESULT OnEvent([in] BSTR eventJson);
};

// Channel — implemented by WindowsTerminal.exe, activated by the client via
// CoCreateInstance(CLSCTX_LOCAL_SERVER). `Ping` exercises plain request/response;
// `Subscribe` wires up the push-event callback.
[
    object,
    uuid(7B3A1E4C-9F22-4D8B-A1C7-3E5F6A0B2D14),
    pointer_default(unique)
] interface IAgentChannel : IUnknown
{
    HRESULT Subscribe([in] IAgentChannelSink* sink);
    HRESULT Unsubscribe();
    HRESULT Ping([in] BSTR input, [out, retval] BSTR* output);
};
