  </data>
  <data name="FreOverlay_AutoErrorDescription.Text" xml:space="preserve">
    <value>Thoir cead do Intelligent Terminal ruigsinneachd fhaighinn air do shlige agus mearachdan a lorg gu fèin-obrachail.</value>
