  <data name="FreOverlay_WelcomeSubtitlePrefix" xml:space="preserve">
    <value>Állítsa be a beépített asszisztenst, amely segít a hibák magyarázatában, parancsok létrehozásában és feladatok feloldásában közvetlenül ott, ahol dolgozik. </value>
