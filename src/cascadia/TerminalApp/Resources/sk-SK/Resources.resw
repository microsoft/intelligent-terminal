  </data>
  <data name="FreOverlay_WelcomeSubtitlePrefix" xml:space="preserve">
    <value>Nastavte si vstavaného asistenta, ktorý vám pomôže vysvetľovať chyby, navrhovať príkazy a odblokovať úlohy priamo tam, kde pracujete. </value>
  </data>
