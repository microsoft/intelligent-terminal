  <data name="FreOverlay_WelcomeSubtitlePrefix" xml:space="preserve">
    <value>चुकी समजावपाक, कमांड तयार करपाक आनी कामां अनब्लॉक करपाक मदत करपा खातीर तुमचो अंतर्निर्मित सहाय्यक सेट अप करात, तुमी जंय काम करतात थंयच. </value>
  </data>
