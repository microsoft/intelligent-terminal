  <data name="FreOverlay_WelcomeSubtitlePrefix" xml:space="preserve">
    <value>Nastavte si vestavěného asistenta, který vám pomůže vysvětlovat chyby, navrhovat příkazy a odblokovat úkoly přímo tam, kde pracujete. </value>
