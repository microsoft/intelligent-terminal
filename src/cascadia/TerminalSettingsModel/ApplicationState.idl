import "Command.idl";
import "GlobalAppSettings.idl";

namespace Microsoft.Terminal.Settings.Model
{
    enum InfoBarMessage
    {
        // We need a sentinel value to map deleted keys to, as we can't actually delete them (GH#16874)
        IgnoredDeprecatedEntry = 0,
        CloseOnExitInfo,
        KeyboardServiceWarning,
    };

    runtimeclass WindowLayout
    {
        WindowLayout();

        static String ToJson(WindowLayout layout);
        static WindowLayout FromJson(String json);

        Windows.Foundation.Collections.IVector<ActionAndArgs> TabLayout;
        Windows.Foundation.IReference<LaunchPosition> InitialPosition;
        Windows.Foundation.IReference<Windows.Foundation.Size> InitialSize;
        Windows.Foundation.IReference<LaunchMode> LaunchMode;
    };

    // Reserved for a future step: the agent pane belonging to a saved
    // workspace tab. Not populated or restored yet — the fields exist so the
    // on-disk schema is forward-compatible when agent-pane restore lands.
    runtimeclass SavedWorkspaceAgentPane
    {
        SavedWorkspaceAgentPane();

        String Cli;            // which agent CLI (copilot/claude/gemini/custom)
        String Model;          // model override, empty for default
        String AgentSessionId; // ACP session key to session/load on restore
        String Position;       // agent pane position at save time
        String ChatHistoryFile; // workspace-relative file of the saved chat UI history
    };

    runtimeclass SavedWorkspaceTab
    {
        SavedWorkspaceTab();

        String SourceStableId; // informational: last live tab this came from
        Windows.Foundation.Collections.IVector<ActionAndArgs> TabActions;
        Windows.Foundation.Collections.IVector<String> BufferSessionIds;
        SavedWorkspaceAgentPane AgentPane; // reserved; may be null
    };

    runtimeclass SavedWorkspaceSession
    {
        SavedWorkspaceSession();

        static String ToJson(SavedWorkspaceSession session);
        static SavedWorkspaceSession FromJson(String json);

        String Id;
        String Title;
        String SavedAt; // decimal Unix epoch milliseconds, as a string
        Windows.Foundation.Collections.IVector<SavedWorkspaceTab> Tabs;
    };

    [default_interface] runtimeclass ApplicationState {
        static ApplicationState SharedInstance();

        void Flush();
        void Reset();

        void AppendPersistedWindowLayout(WindowLayout layout);
        void UpsertSavedWorkspaceSession(SavedWorkspaceSession session);
        Boolean RemoveSavedWorkspaceSession(String id);
        Boolean DismissBadge(String badgeId);
        Boolean BadgeDismissed(String badgeId);

        String SettingsHash;
        Windows.Foundation.Collections.IVector<WindowLayout> PersistedWindowLayouts;
        Windows.Foundation.Collections.IVector<SavedWorkspaceSession> SavedWorkspaceSessions;
        Windows.Foundation.Collections.IVector<String> RecentCommands;
        Windows.Foundation.Collections.IVector<InfoBarMessage> DismissedMessages;
        Windows.Foundation.Collections.IVector<String> AllowedCommandlines;

        Boolean AgentFreCompleted;
        Boolean AgentWelcomeShown;
    }
}
