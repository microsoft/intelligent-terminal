import "ITerminalConnection.idl";

namespace Microsoft.Terminal.TerminalConnection
{
    // Connection used by agent panes when the shared-wta singleton owns
    // the agent CLI process. No HPCON / no child process spawn: just two
    // anonymous pipes that move VT bytes between TermControl and a
    // long-lived wta.exe attached over the COM control channel. See
    // doc/specs/Multi-window-agent-pane.md.
    //
    // Lifecycle:
    //   1. Caller constructs AgentPipeConnection(rows, cols).
    //   2. Caller reads `WtaInputHandle` / `WtaOutputHandle` (HANDLE
    //      values local to *this* process) and `DuplicateHandle`'s them
    //      into wta.exe's address space.
    //   3. Caller sends `_internal.attach_pane` over IProtocolServer
    //      with the duplicated HANDLE integers + tab_id.
    //   4. _MakeTerminalPane(args, sourceTab, agentConn) inserts the
    //      connection into a fresh TermControl as if it were any other
    //      ConptyConnection.
    [default_interface] runtimeclass AgentPipeConnection : ITerminalConnection
    {
        AgentPipeConnection(UInt32 rows, UInt32 columns);

        // HANDLEs (as UInt64) destined for wta.exe. Owned by *this*
        // connection until the caller passes them to DuplicateHandle —
        // after that, the duplicated copies are wta's responsibility,
        // and the originals are closed by AgentPipeConnection.Close().
        UInt64 WtaInputHandle { get; };
        UInt64 WtaOutputHandle { get; };
    };
}
