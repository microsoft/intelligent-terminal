#!/usr/bin/env bash
# PostToolUse hook — forward tool-completed event to Windows Terminal
set -euo pipefail

[ -z "${WT_COM_CLSID:-}" ] && exit 0
command -v wtcli >/dev/null 2>&1 || exit 0

INPUT="$(cat)"
[ -z "$INPUT" ] && exit 0

if [ -n "${COPILOT_CLI:-}" ]; then SRC="copilot"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then SRC="claude"
else SRC="unknown"; fi

wtcli send-event -e "agent.tool.completed" "{\"cli_source\":\"$SRC\",\"payload\":$INPUT}" 2>/dev/null || true
exit 0
